# Managed by Ansible — do not edit manually
# Generated from: roles/wireguard/templates/tunnel.conf.j2

[Interface]
PrivateKey = {{ wireguard_private_key }}
Address    = {{ wireguard_address }}
{% if wireguard_dns is defined and wireguard_dns | length > 0 %}
DNS        = {{ wireguard_dns }}
{% endif %}

[Peer]
PublicKey  = {{ wireguard_peer_public_key }}
Endpoint   = {{ wireguard_peer_endpoint }}
AllowedIPs = {{ wireguard_peer_allowed_ips }}
{% if wireguard_peer_persistent_keepalive is defined and wireguard_peer_persistent_keepalive | int > 0 %}
PersistentKeepalive = {{ wireguard_peer_persistent_keepalive }}
{% endif %}
